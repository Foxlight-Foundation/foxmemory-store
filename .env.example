# ── Inference provider (OpenAI-compatible) ────────────────────────────────────
# Point at hosted OpenAI, a local Ollama proxy, or foxmemory-infer.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...

# LLM used for memory extraction (fact extraction + ADD/UPDATE/DELETE decisions)
MEM0_LLM_MODEL=gpt-4.1-nano

# Embedding model — CANNOT be changed after the collection is created
MEM0_EMBED_MODEL=text-embedding-3-small

# ── Vector store (Qdrant) ─────────────────────────────────────────────────────
# When using the embedded image, Qdrant runs inside the container at 127.0.0.1.
# For a separate Qdrant container, set QDRANT_HOST to that container's hostname.
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=foxmemory
# QDRANT_API_KEY=   # optional — only if Qdrant is configured with an API key

# ── Analytics DB (SQLite) ─────────────────────────────────────────────────────
# MUST be on a mounted volume or all analytics reset on container restart.
FOXMEMORY_ANALYTICS_DB_PATH=/data/foxmemory-analytics.db

# ── Graph memory (Neo4j — optional) ──────────────────────────────────────────
# Leave NEO4J_URL unset to disable graph memory entirely.
# NEO4J_URL=bolt://neo4j:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=changeme
# MEM0_GRAPH_LLM_MODEL=gpt-4.1-mini
# MEM0_GRAPH_CUSTOM_PROMPT=
# MEM0_GRAPH_SEARCH_THRESHOLD=0.7
# MEM0_GRAPH_NODE_DEDUP_THRESHOLD=0.9
# MEM0_GRAPH_BM25_TOPK=5

# ── Internal (rarely needed) ──────────────────────────────────────────────────
# MEM0_HISTORY_DB_PATH=/tmp/history.db   # ephemeral mem0 state, not analytics
# MEM0_ADD_RETRIES=3
# MEM0_ADD_RETRY_DELAY_MS=250
